# Copy to .env and fill in secrets. Never commit .env to git.

# Stripe (required)
Stripe__SecretKey=sk_test_...
Stripe__PublishableKey=pk_test_...
Stripe__WebhookSecret=whsec_...

# Email — Resend (optional in dev; receipts log a warning if missing)
Email__ApiKey=re_...
Email__FromAddress=receipts@brightfuture4children.com
Email__FromName=Bright Future For Children Ethiopia

# PostgreSQL — when running API via Docker Compose (internal network)
# ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=bffc;Username=bffc;Password=devpassword;SSL Mode=Prefer

# PostgreSQL — when running API locally (`dotnet run`) with Compose Postgres on host port 5433
ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=bffc;Username=bffc;Password=devpassword;SSL Mode=Prefer

# PostgreSQL — Azure production example (use App Service settings or Key Vault)
# ConnectionStrings__DefaultConnection=Host=your-server.postgres.database.azure.com;Port=5432;Database=bffc;Username=bffc_admin;Password=YOUR_PASSWORD;SSL Mode=Require

# CORS (comma-separated origins; overrides appsettings when set)
ALLOWED_ORIGINS=http://localhost:3000
