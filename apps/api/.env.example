# Copy this file to .env and fill in your values.
# Get test keys from https://dashboard.stripe.com/test/apikeys
# Webhook secret from: stripe listen --forward-to http://localhost:5000/api/donations/webhook

Stripe__PublishableKey=pk_test_your_publishable_key_here
Stripe__SecretKey=sk_test_your_secret_key_here
Stripe__WebhookSecret=whsec_your_webhook_signing_secret_here

# Tax receipt emails (https://resend.com — free tier works for testing)
# Verify your sending domain in Resend before going to production.
Email__ApiKey=re_your_resend_api_key_here
