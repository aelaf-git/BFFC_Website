# Production site URL (required for correct canonical URLs, sitemap, and Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.your-bffc-domain.org

# URL of the ASP.NET Core API backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Stripe publishable key (safe to expose in the browser — used on the 3DS return page)
# Must match the key configured in apps/api/.env
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
